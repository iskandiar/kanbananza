# Build-time secrets — copy this to .env and fill in your values.
# .env is gitignored; .env.example is committed as a template.
#
# Google Calendar OAuth2 — Desktop app credentials
# https://console.cloud.google.com → APIs & Services → Credentials
GCAL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GCAL_CLIENT_SECRET=your-client-secret
